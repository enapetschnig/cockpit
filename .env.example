# ─────────────────────────────────────────────────────────────
#  ePower Cockpit – Umgebungsvariablen
#  Kopiere diese Datei zu ".env" und trage die Werte ein.
#  ".env" wird NICHT eingecheckt (siehe .gitignore) – hier stehen NIE echte Secrets!
# ─────────────────────────────────────────────────────────────

# ── Datenbank: Supabase PostgreSQL (Schema "cockpit", isoliert) ──
# Projekt: epowergmbh · Region eu-west-2
# >>> Du musst nur [DEIN-DB-PASSWORT] ersetzen. <<<
# Passwort findest du im Supabase-Dashboard:
#   Project Settings → Database → "Database password" (ggf. "Reset" – Achtung: ändert es auch für die Demo-App!)
#   ODER beim Anlegen des Projekts notiert. Anleitung: docs/10-supabase-datenbank.md
#
# Laufzeit (Connection-Pooler, Transaction-Mode, Port 6543):
DATABASE_URL="postgresql://postgres.xyhgckqxowqnzjtoblfs:[DEIN-DB-PASSWORT]@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=cockpit"
# Migrationen / prisma db push (Session-Mode, Port 5432):
DIRECT_URL="postgresql://postgres.xyhgckqxowqnzjtoblfs:[DEIN-DB-PASSWORT]@aws-1-eu-west-2.pooler.supabase.com:5432/postgres?schema=cockpit"

# ── KI: OpenAI ──────────────────────────────────────────────
# Key holen: https://platform.openai.com/api-keys
# Ohne Key läuft die App trotzdem (einfacher Regel-Fallback statt echter KI).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# ── Telegram (Push & Steuerung) – optional ──────────────────
# Bot bei @BotFather erstellen -> Token. Chat-ID via @userinfobot.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ── Gmail (echte Anbindung – Phase 1b) ──────────────────────
# Google Cloud Console -> OAuth-Client (Web) anlegen. Anleitung: docs/09-gmail-anbindung.md
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/gmail/callback"
# Verschlüsselt gespeicherte OAuth-Tokens pro Konto -> setzt der OAuth-Flow.
GMAIL_ACCOUNT_FIRMA=""
GMAIL_ACCOUNT_PRIVAT=""
