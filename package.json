{
  "name": "epower-cockpit",
  "version": "0.1.0",
  "private": true,
  "description": "Kontrollhub für die ePower GmbH – Phase 1: E-Mail-Cockpit mit KI (Zusammenfassung, Labels, Firmenrelevanz), Kunden-Zuordnung & Push.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seedAds": "tsx prisma/seedAds.ts",
    "bmd:upload": "tsx scripts/bmdRunner.ts",
    "db:reset": "prisma db push --force-reset && tsx prisma/seed.ts",
    "setup": "prisma generate && prisma db push && tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "googleapis": "^173.0.0",
    "next": "^15.3.3",
    "openai": "^4.104.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "playwright": "^1.61.0",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
